            couponCodesStored.push(couponCode)
          };
        }catch(error){
          console.log(error);
        }
      };
      couponCodes(authorization);
      // create new coupon code
      const newCouponCode= ()=>{
        let id=null;
        do{
           id = Math.random().toString(36).slice(2, 11);
        }while(couponCodesStored.includes(id))
        return id;
      };
      // validete code code input requst 
      let generateCouponAndSaveSwicth= false;
      let couponDetails=null;
      const generateCoupon= ()=>{
          const amountCouponMessageAlert= document.querySelector('.addmin-coupon-head-text');
          amountCouponMessageAlert.textContent='Generate Coupon Code'; amountCouponMessageAlert.style.color='gray';
          const amountIn = document.querySelector('.ad-coupon-in').value.trim();
          if(amountIn === '') return amountCouponMessageAlert.textContent='amount cant be empty', amountCouponMessageAlert.style.color='red';
