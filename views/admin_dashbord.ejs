      });
      // get all coupon codes
      let couponCodesStored=[]
      const couponCodes= async(a)=>{
        const authorization =a;
        try{
          const url='/admin/cupn/up/g/c';
          const data= await fetch(url, {
            method: 'GET',
            headers: {
              'Authorization' : `Bear ${authorization}`,
