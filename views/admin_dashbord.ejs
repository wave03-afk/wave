          const amount2= amountIn.split(' ')[1]; 
          const amount3= amountIn.split(' ')[2];
          if(!amount1 || !amount2 || !amount3) return amountCouponMessageAlert.textContent='expecting 3 value input', amountCouponMessageAlert.style.color='red';
