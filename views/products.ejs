    //
    document.addEventListener("click", (e) => {
      const target = e.target.closest("[data-buy]");
      if (target) {
        const item = Number(target.dataset.buy);
        const loadingAnimation = document.querySelector(
          ".loading-animation-body"
        );
        loadingAnimation.style.display = "block";
          order(product, item);
      }
    });
    //order product
    const order = async (p, n) => {
      const product = p[n];
      const userData = JSON.parse(localStorage.getItem("Wave_user"));
      const userId = userData.userId;
      const authorization = userData.authorization;
      const url = "/products/p/o/";
      const productDetails = {
        itemName: product.itemName,
        itemPrice: product.itemPrice,
        itemReturnAmount: product.itemReturnAmount,
        userId: userId,
        itemReturnTimePeriod: product.itemReturnTimePeriod,
      };
      try {
        const data = await fetch(url, {
          method: "POST",
          headers: {
            Authorization: `Token ${authorization}`,
            "Content-type": "application/json",
          },
          body: JSON.stringify(productDetails),
        });
        const html = await data.text();
        document.open();
        document.write(html);
        document.close();
      } catch (error) {}
    };
